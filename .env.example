# Kopier denne filen til .env og fyll inn dine innloggingsdetaljer
# .env blir ALDRI commitet til git

# --- Oda.no (påkrevd for bestill-kommandoen og Discord-agenten) ---
ODA_EMAIL=din-epost@eksempel.no
ODA_PASSWORD=ditt-passord

# Valgfritt: sett til false for å se nettleseren under automatisering
# PLAYWRIGHT_HEADLESS=true

# --- Discord-bot (påkrevd for npm run bot) ---
DISCORD_TOKEN=din-discord-bot-token
DISCORD_CHANNEL_ID=kanal-id-boten-skal-bruke

# --- Claude API (påkrevd for npm run bot) ---
ANTHROPIC_API_KEY=din-anthropic-api-nøkkel

# Valgfritt: overstyr datakatalog (standard: ~/.matvareplanlegger/)
# DATA_DIR=/sti/til/datamappe
